{% doc %}
  Spotify playlist facade (click-to-load embed, CWV-safe).
  Reads the playlist URL from theme settings (KONBINI brand group).
  Renders nothing when the setting is blank.

  @param {boolean} [compact] - compact player (152px) instead of full (352px); default true
{% enddoc %}
{%- liquid
  assign playlist_url = settings.konbini_spotify_playlist
  if compact == nil
    assign compact = true
  endif
-%}
{%- if playlist_url != blank -%}
  {%- assign playlist_id = playlist_url | split: 'playlist/' | last | split: '?' | first -%}
  {%- if playlist_id != blank -%}
    <script type="module" src="{{ 'konbini-spotify.js' | asset_url }}"></script>
    <konbini-spotify
      class="konbini-spotify"
      data-playlist-id="{{ playlist_id }}"
      data-compact="{{ compact }}"
      data-iframe-title="{{ 'konbini.spotify.iframe_title' | t }}"
    >
      <button type="button" class="konbini-spotify__facade">
        <svg aria-hidden="true" focusable="false" width="21" height="21" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0Zm5.5 17.3a.75.75 0 0 1-1.03.25c-2.82-1.72-6.37-2.11-10.55-1.16a.75.75 0 1 1-.33-1.46c4.57-1.05 8.5-.6 11.66 1.34.35.22.46.68.25 1.03Zm1.47-3.27a.94.94 0 0 1-1.29.31c-3.23-1.98-8.15-2.56-11.97-1.4a.94.94 0 1 1-.54-1.79c4.36-1.32 9.79-.68 13.49 1.6.44.27.58.85.31 1.28Zm.13-3.41C15.24 8.32 8.94 8.1 5.25 9.22a1.12 1.12 0 1 1-.65-2.15C8.83 5.79 15.83 6.05 20.28 8.7a1.12 1.12 0 0 1-1.18 1.92Z"/></svg>
        <span>{{ 'konbini.spotify.play_label' | t }}</span>
      </button>
    </konbini-spotify>
  {%- endif -%}
{%- endif -%}

{% stylesheet %}
  .konbini-spotify__facade {
    display: inline-flex;
    align-items: center;
    gap: var(--k-space-1);
    padding: var(--k-space-1) var(--k-space-2);
    border: 1px solid var(--k-color-mist);
    border-radius: 100px;
    background: transparent;
    color: inherit;
    font: inherit;
    font-size: 0.8125rem;
    cursor: pointer;
    transition: border-color var(--k-duration-micro) var(--k-ease-out);
  }
  .konbini-spotify__facade:hover {
    border-color: var(--k-color-ink);
  }
{% endstylesheet %}
