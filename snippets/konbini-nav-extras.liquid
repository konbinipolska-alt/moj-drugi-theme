{% doc %}
  Header-bar extras: compact local-store link (pin + address/hours → map) and
  a Spotify popover widget. Rendered inside the header actions cluster
  (fenced call in sections/header.liquid). Both parts hide themselves when
  their settings are blank. The Spotify iframe is in the DOM with
  loading="lazy", so it only loads when the popover first opens — one click
  shows a ready player (no extra load step).
{% enddoc %}
{%- if settings.konbini_store_street != blank -%}
  <a
    class="konbini-nav-store header-actions__action"
    href="{{ settings.konbini_store_maps_url | default: '#' }}"
    {% if settings.konbini_store_maps_url != blank %}target="_blank" rel="noopener"{% endif %}
    aria-label="{{ 'konbini.local_store.heading' | t }} — {{ settings.konbini_store_street }}, {{ 'konbini.local_store.directions' | t }}"
  >
    <svg aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 21s7-5.1 7-11a7 7 0 1 0-14 0c0 5.9 7 11 7 11Z"/><circle cx="12" cy="10" r="2.6"/></svg>
    <span class="konbini-nav-store__text">
      {{- settings.konbini_store_street -}}
      {%- if settings.konbini_store_hours != blank %} · {{ settings.konbini_store_hours }}{% endif -%}
    </span>
  </a>
{%- endif -%}
{%- liquid
  assign playlist_url = settings.konbini_spotify_playlist
-%}
{%- if playlist_url != blank -%}
  {%- assign playlist_id = playlist_url | split: 'playlist/' | last | split: '?' | first -%}
  {%- if playlist_id != blank -%}
    <script type="module" src="{{ 'konbini-spotify.js' | asset_url }}"></script>
    <konbini-spotify-nav class="konbini-nav-spotify">
      <button
        type="button"
        class="konbini-nav-spotify__toggle header-actions__action"
        aria-expanded="false"
        aria-label="{{ 'konbini.spotify.play_label' | t }}"
      >
        <svg aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0Zm5.5 17.3a.75.75 0 0 1-1.03.25c-2.82-1.72-6.37-2.11-10.55-1.16a.75.75 0 1 1-.33-1.46c4.57-1.05 8.5-.6 11.66 1.34.35.22.46.68.25 1.03Zm1.47-3.27a.94.94 0 0 1-1.29.31c-3.23-1.98-8.15-2.56-11.97-1.4a.94.94 0 1 1-.54-1.79c4.36-1.32 9.79-.68 13.49 1.6.44.27.58.85.31 1.28Zm.13-3.41C15.24 8.32 8.94 8.1 5.25 9.22a1.12 1.12 0 1 1-.65-2.15C8.83 5.79 15.83 6.05 20.28 8.7a1.12 1.12 0 0 1-1.18 1.92Z"/></svg>
      </button>
      <div class="konbini-nav-spotify__panel" hidden>
        <iframe
          src="https://open.spotify.com/embed/playlist/{{ playlist_id | url_encode }}?theme=0"
          width="100%"
          height="152"
          style="border: 0; border-radius: 12px;"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
          title="{{ 'konbini.spotify.iframe_title' | t }}"
        ></iframe>
      </div>
    </konbini-spotify-nav>
  {%- endif -%}
{%- endif -%}
